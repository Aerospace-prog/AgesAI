# ============================================
# AgesAI — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables have sensible defaults
# ============================================

# ── Application ──
APP_NAME=ages-ai
APP_ENV=development                    # development | staging | production
APP_VERSION=0.1.0
LOG_LEVEL=debug                        # debug | info | warn | error

# ── API Gateway (Go) ──
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_READ_TIMEOUT=30s
GATEWAY_WRITE_TIMEOUT=30s
GATEWAY_IDLE_TIMEOUT=120s
GATEWAY_RATE_LIMIT_RPS=60             # Requests per second per user
GATEWAY_RATE_LIMIT_BURST=10

# ── Authentication — Clerk [REQUIRED] ──
CLERK_PUBLISHABLE_KEY=pk_test_...     # From Clerk Dashboard → API Keys
CLERK_SECRET_KEY=sk_test_...          # From Clerk Dashboard → API Keys
CLERK_WEBHOOK_SECRET=whsec_...        # From Clerk Dashboard → Webhooks
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── LLM Providers [REQUIRED — at least one] ──
OPENAI_API_KEY=sk-...                 # From platform.openai.com
ANTHROPIC_API_KEY=sk-ant-...          # From console.anthropic.com

# ── LLM Configuration ──
DEFAULT_CHAT_MODEL=gpt-4o             # Model used for RAG chat
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_AGENT_MODEL=gpt-4o            # Model used for agents
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=512
MAX_TOKENS_PER_REQUEST=4096
LLM_REQUEST_TIMEOUT=120               # Seconds

# ── PostgreSQL ──
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=agesai
POSTGRES_USER=agesai
POSTGRES_PASSWORD=agesai_dev_password  # [CHANGE IN PRODUCTION]
DATABASE_URL=postgresql://agesai:agesai_dev_password@postgresql:5432/agesai

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                        # Empty for local dev
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ── Qdrant ──
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                        # Empty for local dev
QDRANT_URL=http://qdrant:6333

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=ages-ai
KAFKA_AUTO_OFFSET_RESET=earliest

# ── MinIO (S3-Compatible Storage) ──
MINIO_ROOT_USER=agesai
MINIO_ROOT_PASSWORD=agesai_minio_dev   # [CHANGE IN PRODUCTION]
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=ages-ai-storage
MINIO_USE_SSL=false
S3_ACCESS_KEY=agesai
S3_SECRET_KEY=agesai_minio_dev
S3_ENDPOINT=http://minio:9000
S3_BUCKET=ages-ai-storage

# ── Service URLs (internal Docker network) ──
EMBEDDING_SERVICE_URL=http://embedding:8001
SEARCH_SERVICE_URL=http://search:8002
RAG_SERVICE_URL=http://rag:8003
AGENT_SERVICE_URL=http://agent:8004
REVIEW_SERVICE_URL=http://review:8005
DIAGRAM_SERVICE_URL=http://diagram:8006
PLANNER_SERVICE_URL=http://planner:8007

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=AgesAI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenTelemetry ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=ages-ai
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0           # 1.0 = sample everything in dev

# ── Monitoring ──
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin           # [CHANGE IN PRODUCTION]
LOKI_PORT=3100
JAEGER_UI_PORT=16686
